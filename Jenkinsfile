pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                echo 'Pulling the code from Git...'
            }
        }
        stage('Build') {
            steps {
                echo 'Building the project... (Pretend work happens here)'
            }
        }
        stage('Test') {
            steps {
                echo 'Running tests... All green!'
            }
        }
    }
}